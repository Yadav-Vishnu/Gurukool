# ========================================
# Gurukool Backend Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to Git!

# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gurukool
DB_USER=gurukool_admin
DB_PASSWORD=gurukool_secure_2025

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=gurukool_redis_2025

# JWT Secrets (generate strong random strings for production!)
JWT_ACCESS_SECRET=gurukool-access-secret-change-this-in-production-min32chars
JWT_REFRESH_SECRET=gurukool-refresh-secret-change-this-in-production-min32chars

# Google OAuth 2.0
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# SMS Provider (MSG91 for India)
SMS_API_KEY=your-msg91-api-key
SMS_SENDER_ID=GURKOL
SMS_TEMPLATE_ID=your-msg91-template-id

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:8100
